<DefaultWindow  xmlns="https://spacestation14.io"
                          xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                          SetSize="1280 720"
                          MinSize="1280 720"
                          Name="Window"
                          Title="{Loc ui-roadmap}">
    <PanelContainer>
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxFlat
                BackgroundColor="#1d1c1c"
                ContentMarginLeftOverride="10"
                ContentMarginRightOverride="10"/>
        </PanelContainer.PanelOverride>
        <ScrollContainer Name="Scroll" VerticalExpand="True" HScrollEnabled="False">
            <GridContainer Name="MainBox" Columns="3"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          Margin="0 10 0 10">
            </GridContainer>
        </ScrollContainer>
    </PanelContainer>
</DefaultWindow>
