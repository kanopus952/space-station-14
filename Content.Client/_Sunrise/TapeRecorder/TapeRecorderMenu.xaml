<ui:FancyWindow xmlns="https://spacestation14.io"
                xmlns:ui="clr-namespace:Content.Client.UserInterface.Controls"
                xmlns:tape="clr-namespace:Content.Client._Sunrise.TapeRecorder"
                SetSize="560 190"
                Title="{Loc 'tape-recorder-ui-title'}"
                Resizable="False">
    <BoxContainer Margin="6 4" Orientation="Vertical" SeparationOverride="4">
        <Label Name="CassetteLabel" Text="{Loc 'tape-recorder-ui-no-cassette'}" />
        <tape:TapeRecorderTimeline Name="PlaybackTimeline" HorizontalExpand="True" MinSize="0 18" />
        <Label Name="TimeLabel" Text="" />
        <PanelContainer StyleClasses="LowDivider" />
        <BoxContainer Orientation="Horizontal" SeparationOverride="4">
            <Button Name="StopButton" MinWidth="132" MaxWidth="132" Text="{Loc 'tape-recorder-ui-button-stop'}" />
            <Button Name="RecordButton" MinWidth="132" MaxWidth="132" Text="{Loc 'tape-recorder-ui-button-record'}" />
            <Button Name="PlayButton" MinWidth="132" MaxWidth="132" Text="{Loc 'tape-recorder-ui-button-play'}" />
            <Button Name="RewindButton" MinWidth="132" MaxWidth="132" Text="{Loc 'tape-recorder-ui-button-rewind'}" />
        </BoxContainer>
        <Button Name="PrintButton" HorizontalExpand="True" Text="{Loc 'tape-recorder-ui-button-print'}" />
    </BoxContainer>
</ui:FancyWindow>
