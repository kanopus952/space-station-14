<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      SetSize="1120 600"
                      MinSize="1120 560"
                      Resizable="False"
                      Title="{Loc ui-tutorial}">
    <BoxContainer Orientation="Horizontal"
                  HorizontalExpand="True"
                  VerticalExpand="True"
                  SeparationOverride="8"
                  Margin="8">
        <BoxContainer Name="CategoryContainer"
                      Orientation="Vertical"
                      MinWidth="220"
                      VerticalExpand="True"
                      SeparationOverride="4"/>

        <PanelContainer StyleClasses="TutorialDivider"
                        VerticalExpand="True"
                        SetWidth="2"/>

        <BoxContainer Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      SeparationOverride="8">
            <Label Text="{Loc 'ui-tutorial-available'}"
                   HorizontalAlignment="Center"
                   StyleClasses="LabelHeading"/>

            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True"
                          SeparationOverride="2">
                <Label Name="CategoryProgressLabel"
                       HorizontalAlignment="Center"
                       HorizontalExpand="True"/>

                <ProgressBar Name="CategoryProgressBar"
                             HorizontalExpand="True"
                             MinValue="0"
                             MaxValue="1"
                             SetHeight="18"
                             MinHeight="18"/>
            </BoxContainer>

            <ScrollContainer VScrollEnabled="True"
                             HorizontalExpand="True"
                             VerticalExpand="True">
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True">
                    <Control HorizontalExpand="True"/>

                    <GridContainer Name="ButtonGrid"
                                   Columns="2"
                                   HSeparationOverride="8"
                                   VSeparationOverride="8"
                                   HorizontalAlignment="Center"/>

                    <Control HorizontalExpand="True"/>
                </BoxContainer>
            </ScrollContainer>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
