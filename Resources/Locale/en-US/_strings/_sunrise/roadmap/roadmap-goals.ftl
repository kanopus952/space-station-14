# Groups
roadmap-available-now = Already Available
roadmap-in-progress = In Development
roadmap-planned = Planned

# ---- Already Available ----

roadmap-goal-fugitive-name = Fugitive
    .desc = An escaped prisoner whose goal is to survive.

roadmap-goal-planet-prison-name = Planet Prison
    .desc = A prison on a planet, functioning as a separate station.

roadmap-goal-cyborg-update-name = Station Borgs
    .desc = New borgs.

roadmap-goal-collective-mind-name = Collective Mind
    .desc = A system allowing certain creatures to communicate with each other.

roadmap-goal-syndicate-cyborgs-name = Syndicate Borgs
    .desc = More advanced and useful syndicate borgs.

roadmap-goal-new-guns-name = Expanded Firearms
    .desc = Adding a variety of firearms (what about a flamethrower?).

roadmap-goal-smart-viruse-name = Intelligent Disease
    .desc = An antagonist whose goal is to infect the station with a disease.

roadmap-goal-cargo-rework-name = Cargo Rework
    .desc = Removal of the trade outpost and cargo shuttle, implementing buying and selling on the station.

roadmap-goal-new-maps-name = Global Map Rework
    .desc = Significant improvements to maps (Delta, Box).

roadmap-goal-fully-translating-name = Full Translation
    .desc = Translation of all items and interfaces to simplify gameplay.

roadmap-goal-mechs-name = Mechs
    .desc = Piloted mechanoids for working in hard-to-reach places and transporting cargo.

roadmap-goal-assault-ops-name = Assault Squad
    .desc = A squad of mercenaries whose goal is to covertly sabotage the station.

roadmap-goal-flesh-cult-name = Flesh Cult
    .desc = A flesh cult whose goal is to destroy the station.

roadmap-goal-blood-cult-name = Blood Cult (Nar'Sie)
    .desc = A cult of the god Nar'Sie, whose goal is to summon their patron and destroy the station.

roadmap-goal-vent-crawling-name = Vent Crawling
    .desc = Ability for small creatures and antagonists to travel through the ventilation system.

roadmap-goal-new-gases-name = New Gases
    .desc = New atmospheric gases with unique properties and effects.

roadmap-goal-shooting-name = Shooting Rework
    .desc = Improvements to shooting mechanics and weapon interaction.

roadmap-goal-surgery-name = Surgery
    .desc = Expanded surgery mechanics and medical procedures.

roadmap-goal-angels-name = Angel Race
    .desc = A new race of angels with their own unique abilities.

# ---- In Development ----

roadmap-goal-virusology-name = Virology
    .desc = Reviving virology — you will be able to create and research diseases.

roadmap-goal-ingame-tutorial-name = In-Game Tutorial
    .desc = A tutorial mode for new players inside the game itself.

roadmap-goal-vampires-name = Vampires
    .desc = An antagonist who feeds on crew blood and can turn victims into servants.

roadmap-goal-pirates-name = Pirates
    .desc = A squad of space pirates raiding the station for loot.

roadmap-goal-alt-jobs-name = Alternative Jobs
    .desc = New alternative jobs and roles to diversify gameplay.

# ---- Planned ----

roadmap-goal-economy-name = Economy
    .desc = Adding money and salaries. Mail will provide income, vending machines will charge for food.

roadmap-goal-ipc-name = IPC
    .desc = A race of sapient machines, currently in development.

roadmap-goal-ert-call-name = ERT Call Console
    .desc = A console used to call the Emergency Response Team.

roadmap-goal-blob-name = Blob
    .desc = An antagonist whose goal is to consume and destroy the station.

roadmap-goal-station-goals-rework-name = Station Goals Rework
    .desc = Implementation of a CentCom task console instead of a single-goal paper. Completing goals rewards the station with money.

roadmap-goal-borer-name = Brain Worm
    .desc = An antagonist that crawls into the brains of living creatures and takes over their mind.

roadmap-goal-perks-name = New Perks
    .desc = A variety of new character traits to diversify gameplay.

roadmap-goal-arena-name = Ghost Arena
    .desc = An arena where ghosts can spend their time instead of floating around the station waiting for the round to end.

roadmap-goal-limbo-name = Limbo
    .desc = A separate world for ghosts where there are no rules.
